.App {
  font-family: Arial, sans-serif;
  padding: 20px;
}
.dashboard {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 20px;
}
.panels {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.panel {
  border: 1px solid #ccc;
  padding: 10px;
  border-radius: 5px;
}
.order-form {
  grid-column: 1 / -1;
  border-top: 2px solid #333;
  padding-top: 20px;
}
